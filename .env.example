# Database
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=nostrmap
MYSQL_USER=nostrmap
MYSQL_PASSWORD=changeme_db

# JWT
JWT_SECRET=changeme_jwt_secret_min32chars_random
TOTP_ENCRYPTION_KEY=changeme_totp_encryption_key_min32chars_random

# App
APP_URL=https://nostrmap.fr
APP_ENV=production

# Notifications admin Discord (optionnel)
# Ne jamais committer l'URL réelle du webhook.
DISCORD_WEBHOOK_URL=
DISCORD_USER_ID=

# Cron (optionnel, pour les scripts CLI)
CRON_RECHECK_BATCH=50
